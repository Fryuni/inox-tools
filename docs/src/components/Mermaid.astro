---
import { renderMermaidToSvg } from '../utils/mermaid';

export interface Props {
	code: string;
	alt?: string;
}

const { code, alt = 'Mermaid Diagram' } = Astro.props;

let lightSvg = '';
let darkSvg = '';

try {
	[lightSvg, darkSvg] = await Promise.all([
		renderMermaidToSvg(code, 'default'),
		renderMermaidToSvg(code, 'dark'),
	]);
} catch (e) {
	console.error('[Mermaid] Build-time render failed:', e);
}
---

<div class="mermaid-container" role="img" aria-label={alt}>
	<div class="mermaid-light" set:html={lightSvg} />
	<div class="mermaid-dark" set:html={darkSvg} />
</div>

<style>
	.mermaid-container {
		display: flex;
		justify-content: center;
		margin: 1rem 0;
	}

	.mermaid-dark {
		display: none;
	}

	:root[data-theme='dark'] .mermaid-light {
		display: none;
	}

	:root[data-theme='dark'] .mermaid-dark {
		display: block;
	}
</style>
