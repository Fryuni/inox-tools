---
import { getEntryGitInfo } from '@it-astro:content/git';
import { getCollection } from 'astro:content';

const [entry] = await getCollection('entries');
const info = await getEntryGitInfo({ collection: 'entries', id: entry.id });

const data = {
	earliest: info?.earliest.toISOString(),
	latest: info?.latest.toISOString(),
};
---

<pre id="data">{JSON.stringify(data)}</pre>
